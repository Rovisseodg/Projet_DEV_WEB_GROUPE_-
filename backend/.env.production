APP_NAME=MaMutuelle
APP_ENV=production
APP_DEBUG=false
APP_URL=https://mamutuelle.railway.app

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=${DATABASE_URL_HOST}
DB_PORT=${DATABASE_URL_PORT}
DB_DATABASE=${DATABASE_URL_DATABASE}
DB_USERNAME=${DATABASE_URL_USER}
DB_PASSWORD=${DATABASE_URL_PASSWORD}

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file

JWT_SECRET=${JWT_SECRET}
JWT_ALGORITHM=HS256
JWT_TTL=60

CORS_ALLOWED_ORIGINS=*
