# ========================================
# MaMutuelle - Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# ========== APPLICATION ==========
APP_NAME=MaMutuelle
APP_ENV=production
APP_DEBUG=false
APP_KEY=base64:YOUR_APP_KEY_HERE_GENERATE_WITH_artisan_key_generate
APP_URL=https://your-app.onrender.com

# ========== DATABASE (PostgreSQL) ==========
DB_CONNECTION=pgsql
DB_HOST=your-db-host.render.com
DB_PORT=5432
DB_DATABASE=your_database_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# Optional: External database connection string (for Render)
# DATABASE_URL=postgresql://user:password@host:port/database

# ========== LOGGING ==========
LOG_CHANNEL=stderr
LOG_LEVEL=info

# ========== SESSION & CACHE ==========
SESSION_DRIVER=file
CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=sync

# ========== JWT CONFIGURATION ==========
JWT_SECRET=your_jwt_secret_key_here
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_ALGORITHM=HS256

# ========== RENDER SPECIFIC ==========
# Set to 'true' only on first deployment to run migrations
RUN_MIGRATIONS=true
DB_MIGRATED=false
