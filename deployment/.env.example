# MaMutuelle Environment Configuration

# ============================================
# APPLICATION
# ============================================
APP_NAME="MaMutuelle"
APP_ENV=local
APP_KEY=base64:...change-me...
APP_DEBUG=true
APP_URL=http://localhost:8000

# ============================================
# DATABASE - PostgreSQL
# ============================================
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=mamutuelle
DB_USERNAME=postgres
DB_PASSWORD=your_password_here

# ============================================
# CACHE & SESSION
# ============================================
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ============================================
# AUTHENTICATION - JWT
# ============================================
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES=3600
JWT_REFRESH_EXPIRES=604800

# ============================================
# EMAIL - SendGrid
# ============================================
MAIL_MAILER=sendgrid
MAIL_HOST=smtp.sendgrid.net
MAIL_PORT=587
MAIL_USERNAME=apikey
MAIL_PASSWORD=SG.xxxxxxxxxxxxx
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@mamutuelle.fr
MAIL_FROM_NAME="MaMutuelle"

# ============================================
# STORAGE
# ============================================
FILESYSTEM_DISK=local
FILESYSTEM_VISIBILITY=private

# ============================================
# SECURITY
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=1

# ============================================
# LOGGING
# ============================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ============================================
# AWS S3 (Optional pour uploads)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=

# ============================================
# STRIPE (Optional pour paiements)
# ============================================
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# ============================================
# TWILIO (Optional pour SMS)
# ============================================
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
